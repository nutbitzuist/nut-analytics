# === Required for dashboard protection (recommended) ===
DASHBOARD_PASSWORD=change-me-in-production
# Even better (generate with: node scripts/generate-password-hash.mjs "your-password"):
# DASHBOARD_PASSWORD_HASH=...

# Optional but recommended
SESSION_SECRET=another-long-random-string
AUTH_EMAIL=you@yourdomain.com

# === Optional: daily/weekly reports ===
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...
# RESEND_API_KEY=...
# REPORT_EMAIL_TO=you@example.com
# REPORT_EMAIL_FROM="Nut Analytics <reports@yourdomain.com>"
# ANTHROPIC_API_KEY=...           # for AI growth memos
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# REPORT_HOUR_UTC=1

# === Optional: Stripe revenue attribution ===
STRIPE_WEBHOOK_SECRET=whsec_...

# === For tests (uses in-memory DB) ===
# ANALYTICS_DB_PATH=:memory:

# === Rate limit tuning (defaults are reasonable) ===
# Higher numbers = more permissive
